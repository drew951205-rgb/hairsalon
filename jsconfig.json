{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "baseUrl": "."
  },
  "include": ["src/**/*.js", "src/**/*.jsx", "api/**/*.js", "server.js", "vite.config.js"],
  "exclude": ["node_modules", "dist", "vov-hair-salon", ".vercel"]
}
