# Sanity project settings are centralized in sanity.shared.js.
# Do not duplicate VITE_SANITY_* values here unless you are intentionally
# validating that local env matches the shared config.

# Email configuration
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-app-password

# Alternative SMTP configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_SECURE=false

# Contact form recipient
CONTACT_EMAIL_RECIPIENT=your-email@example.com
